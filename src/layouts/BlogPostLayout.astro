---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTASection from "@components/CTASection.astro";
import FAQ from "@components/FAQ.astro";
import InternalLinks from "@components/InternalLinks.astro";
import { blogPosts, getPost, type BlogPost } from "@data/blog";
import { getService } from "@data/services";
import { site } from "@data/site";
import { buildGraph, breadcrumbNode, businessId } from "@data/schema";

type Props = {
  post: BlogPost;
};

const { post } = Astro.props;
const relatedServices = post.relatedServices.map((slug) => getService(slug)).filter(Boolean);
const relatedPost = post.relatedPost ? getPost(post.relatedPost) : blogPosts.find((item) => item.slug !== post.slug);
const pageUrl = new URL(`/blog/${post.slug}/`, site.url).toString();
const crumbs = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog/" },
  { label: post.title }
];
const articleSchema = {
  "@type": "BlogPosting",
  headline: post.title,
  description: post.description,
  datePublished: post.date,
  dateModified: post.dateModified ?? post.date,
  image: new URL("/crawl-space-hero.jpg", site.url).toString(),
  author: { "@id": businessId },
  publisher: { "@id": businessId },
  isPartOf: { "@id": `${site.url}/#website` },
  inLanguage: "en-US",
  url: pageUrl,
  mainEntityOfPage: pageUrl
};
const faqSchema = {
  "@type": "FAQPage",
  mainEntity: post.faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  }))
};
const schema = buildGraph([articleSchema, faqSchema, breadcrumbNode(crumbs)]);
---

<BaseLayout title={`${post.title} | Henry Crawl Solutions`} description={post.description} canonical={`/blog/${post.slug}/`} schema={schema}>
  <Breadcrumbs crumbs={crumbs} />
  <article>
    <header class="relative overflow-hidden border-b border-stonewash/70 bg-mesh py-16">
      <div class="pointer-events-none absolute -right-24 -top-20 h-72 w-72 rounded-full bg-forest-200/40 blur-3xl"></div>
      <div class="container relative max-w-4xl animate-fade-up">
        <span class="eyebrow"><span class="h-1.5 w-1.5 rounded-full bg-clay"></span>Crawl Space Guide</span>
        <h1 class="font-display mt-5 text-4xl font-semibold leading-[1.05] text-ink sm:text-5xl">{post.title}</h1>
        <p class="mt-6 text-lg leading-8 text-ink/70">{post.description}</p>
      </div>
    </header>
    <div class="container grid gap-12 py-16 lg:grid-cols-[minmax(0,1fr)_340px]">
      <div class="prose-content max-w-none">
        <slot />
        <section class="mt-14">
          <h2 class="font-display text-3xl font-semibold text-ink">Related services</h2>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            {relatedServices.map((service) => service && (
              <a class="focus-ring inline-flex items-center justify-between gap-2 rounded-2xl border border-stonewash/80 bg-white p-4 font-bold text-forest-700 shadow-card transition hover:-translate-y-0.5 hover:border-forest-300" href={`/${service.slug}/`}>
                {service.title}
                <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 text-forest-400" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg>
              </a>
            ))}
          </div>
        </section>
        <section class="mt-14">
          <h2 class="font-display mb-7 text-3xl font-semibold text-ink">Questions homeowners ask</h2>
          <FAQ items={post.faqs} />
        </section>
      </div>
      <aside class="space-y-5 lg:sticky lg:top-28 lg:self-start">
        <InternalLinks
          title="Next steps"
          links={[
            { label: "McDonough service area", href: "/service-areas/mcdonough-ga/" },
            { label: "Request an inspection", href: "/contact/" },
            ...(relatedPost ? [{ label: relatedPost.title, href: `/blog/${relatedPost.slug}/` }] : [])
          ]}
        />
        <div class="card p-7">
          <h2 class="text-lg font-extrabold text-ink">Contact</h2>
          <p class="mt-3 text-sm leading-6 text-ink/65">Call <a class="font-bold text-forest-700" href={site.phoneHref}>{site.phone}</a> or request a free crawl space inspection online.</p>
          <a class="btn-primary mt-5 w-full" href="/contact/">Request inspection</a>
        </div>
      </aside>
    </div>
  </article>
  <CTASection title="Need help with your crawl space?" />
</BaseLayout>

<style>
  .prose-content :global(h2) {
    margin-top: 2.25rem;
    color: #13201a;
    font-family: Fraunces, ui-serif, Georgia, serif;
    font-size: clamp(1.7rem, 2vw, 2.1rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .prose-content :global(p) {
    margin-top: 1rem;
    color: #3c4943;
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .prose-content :global(ul) {
    margin-top: 1.25rem;
    display: grid;
    gap: 0.6rem;
  }

  .prose-content :global(li) {
    position: relative;
    padding: 0.95rem 1rem 0.95rem 2.5rem;
    color: #3c4943;
    background: #ffffff;
    border: 1px solid rgba(228, 235, 229, 0.8);
    border-radius: 1rem;
    box-shadow: 0 4px 14px rgba(19, 32, 26, 0.04);
  }

  .prose-content :global(li)::before {
    content: "";
    position: absolute;
    left: 1rem;
    top: 1.35rem;
    height: 0.5rem;
    width: 0.5rem;
    border-radius: 9999px;
    background: #c06a3f;
  }

  .prose-content :global(h3) {
    margin-top: 1.85rem;
    color: #13201a;
    font-weight: 800;
    font-size: 1.2rem;
    line-height: 1.35;
  }

  .prose-content :global(a) {
    color: #1f5132;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s ease;
  }

  .prose-content :global(a:hover) {
    color: #2c7a4b;
  }

  .prose-content :global(strong) {
    color: #13201a;
    font-weight: 700;
  }

  .prose-content :global(.table-wrap) {
    margin-top: 1.5rem;
    overflow-x: auto;
    border: 1px solid rgba(228, 235, 229, 0.8);
    border-radius: 1rem;
    box-shadow: 0 4px 14px rgba(19, 32, 26, 0.04);
  }

  .prose-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.97rem;
    background: #ffffff;
  }

  .prose-content :global(th),
  .prose-content :global(td) {
    padding: 0.85rem 1rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid rgba(228, 235, 229, 0.8);
    color: #3c4943;
    line-height: 1.6;
  }

  .prose-content :global(th) {
    background: #f3f7f4;
    color: #13201a;
    font-weight: 700;
  }

  .prose-content :global(tr:last-child td) {
    border-bottom: none;
  }

  .prose-content :global(.key-takeaway) {
    margin-top: 1.5rem;
    padding: 1.1rem 1.25rem;
    border-left: 4px solid #1f5132;
    background: rgba(31, 81, 50, 0.06);
    border-radius: 0.85rem;
    font-weight: 600;
    color: #2a3a32;
    line-height: 1.7;
  }
</style>
