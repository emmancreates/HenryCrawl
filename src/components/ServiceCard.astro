---
import { serviceIcons } from "@data/icons";
import type { ServiceSlug } from "@data/services";

type Props = {
  title: string;
  href: string;
  excerpt: string;
  slug?: ServiceSlug;
  image?: string;
  imageAlt?: string;
};

const { title, href, excerpt, slug, image, imageAlt } = Astro.props;
const imageWebp = image?.replace(/\.(png|jpe?g)$/i, ".webp");
const iconPaths = slug ? serviceIcons[slug] : '<path d="M4 12c3-4 6 4 9 0s4-4 7-1"/><path d="M4 7c3-4 6 4 9 0s4-4 7-1"/>';
---

<article class="card group relative overflow-hidden hover:-translate-y-1 hover:border-forest-200 hover:shadow-lift">
  <div class="pointer-events-none absolute -right-12 -top-12 h-28 w-28 rounded-full bg-forest-50 opacity-0 transition duration-300 group-hover:opacity-100"></div>
  {image && imageAlt && (
    <picture class="contents">
      <source srcset={imageWebp} type="image/webp" />
      <img
        class="aspect-[3/2] w-full object-cover transition duration-500 group-hover:scale-[1.03]"
        src={image}
        alt={imageAlt}
        width="1200"
        height="800"
        loading="lazy"
        decoding="async"
      />
    </picture>
  )}
  <div class:list={["relative", image ? "p-6" : "p-7"]}>
    <div class="mb-6 grid h-14 w-14 place-items-center rounded-2xl bg-forest-radial text-white shadow-glow transition duration-300 group-hover:scale-105">
      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths} />
    </div>
    <h2 class="text-xl font-extrabold leading-tight text-ink">
      <a class="focus-ring rounded-md after:absolute after:inset-0" href={href}>{title}</a>
    </h2>
    <p class="mt-3 text-sm leading-6 text-ink/65">{excerpt}</p>
    <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-bold text-forest-700">
      Explore service
      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 transition group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg>
    </span>
  </div>
</article>
