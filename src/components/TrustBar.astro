---
import { trustItems } from "@data/site";
---

<section class="border-b border-stonewash/70 bg-white/60">
  <div class="container grid gap-3 py-6 sm:grid-cols-2 lg:grid-cols-4">
    {trustItems.map((item) => (
      <div class="flex items-center gap-3 rounded-2xl border border-stonewash/70 bg-cream/60 px-4 py-3.5 transition hover:border-forest-200 hover:bg-white">
        <span class="grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-forest-50 text-forest-600">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
        </span>
        <span class="text-sm font-bold text-ink">{item}</span>
      </div>
    ))}
  </div>
</section>
