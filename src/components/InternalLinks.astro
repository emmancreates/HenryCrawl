---
type LinkItem = {
  label: string;
  href: string;
};

type Props = {
  title?: string;
  links: LinkItem[];
};

const { title = "Helpful links", links } = Astro.props;
---

<aside class="rounded-3xl border border-stonewash/80 bg-sand/60 p-7">
  <h2 class="text-lg font-extrabold text-ink">{title}</h2>
  <div class="mt-5 flex flex-wrap gap-2.5">
    {links.map((link) => (
      <a class="focus-ring inline-flex items-center gap-1.5 rounded-full border border-stonewash bg-white px-4 py-2 text-sm font-bold text-forest-700 transition hover:-translate-y-0.5 hover:border-forest-300 hover:shadow-card" href={link.href}>
        {link.label}
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-3.5 w-3.5 text-forest-400" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7" /><path d="M8 7h9v9" /></svg>
      </a>
    ))}
  </div>
</aside>
