---
import { site } from "@data/site";
import { locations } from "@data/locations";
---

<form
  class="card relative overflow-hidden p-7 sm:p-9"
  name="inspection-request"
  method="POST"
  action="/thank-you/"
  data-netlify="true"
  netlify-honeypot="bot-field"
>
  <input type="hidden" name="form-name" value="inspection-request" />
  <p class="hidden">
    <label>Do not fill this out: <input name="bot-field" /></label>
  </p>

  <div class="grid gap-5 md:grid-cols-2">
    <label class="block text-sm font-bold text-ink">
      Name
      <input class="mt-2 w-full rounded-xl border border-stonewash bg-white px-4 py-3 text-base font-normal text-ink transition focus:border-forest-500 focus:outline-none focus:ring-4 focus:ring-forest-100" name="name" autocomplete="name" required />
    </label>
    <label class="block text-sm font-bold text-ink">
      Phone
      <input class="mt-2 w-full rounded-xl border border-stonewash bg-white px-4 py-3 text-base font-normal text-ink transition focus:border-forest-500 focus:outline-none focus:ring-4 focus:ring-forest-100" type="tel" name="phone" autocomplete="tel" inputmode="tel" required />
    </label>
    <label class="block text-sm font-bold text-ink">
      Email
      <input class="mt-2 w-full rounded-xl border border-stonewash bg-white px-4 py-3 text-base font-normal text-ink transition focus:border-forest-500 focus:outline-none focus:ring-4 focus:ring-forest-100" type="email" name="email" autocomplete="email" />
    </label>
    <label class="block text-sm font-bold text-ink">
      Service Area
      <select class="mt-2 w-full rounded-xl border border-stonewash bg-white px-4 py-3 text-base font-normal text-ink transition focus:border-forest-500 focus:outline-none focus:ring-4 focus:ring-forest-100" name="service-area">
        {locations.map((location) => <option>{location.city}, GA</option>)}
        <option>Nearby area</option>
      </select>
    </label>
  </div>
  <label class="mt-5 block text-sm font-bold text-ink">
    What are you seeing?
    <textarea class="mt-2 min-h-36 w-full rounded-xl border border-stonewash bg-white px-4 py-3 text-base font-normal text-ink transition focus:border-forest-500 focus:outline-none focus:ring-4 focus:ring-forest-100" name="message" placeholder="Musty odor, standing water, damaged vapor barrier, humid crawl space, or another concern"></textarea>
  </label>
  <button class="btn-primary mt-7 w-full md:w-auto" type="submit">
    {site.primaryCta}
    <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg>
  </button>
  <p class="mt-4 text-sm text-ink/60">You can also call <a class="font-bold text-forest-700" href={site.phoneHref}>{site.phone}</a> or email <a class="font-bold text-forest-700" href={site.emailHref}>{site.email}</a>.</p>
</form>
