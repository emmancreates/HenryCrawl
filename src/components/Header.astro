---
import { navLinks, site } from "@data/site";

const path = Astro.url.pathname;
const isActive = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));
---

<header class="sticky top-0 z-50 border-b border-stonewash/70 bg-cream/80 backdrop-blur-xl">
  <div class="container flex min-h-[4.75rem] items-center justify-between gap-5">
    <a href="/" class="focus-ring group flex items-center gap-3 rounded-2xl" aria-label="Henry Crawl Solutions home">
      <span class="grid h-11 w-11 place-items-center rounded-2xl bg-forest-radial text-white shadow-glow transition group-hover:scale-105">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 11.5 12 4l9 7.5" />
          <path d="M6 10.5V20h12v-9.5" />
          <path d="M8.5 16.5h7" />
          <path d="M9.5 13.5h5" />
        </svg>
      </span>
      <span>
        <span class="block text-base font-extrabold leading-tight text-ink">{site.name}</span>
        <span class="hidden text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-forest-600 sm:block">{site.domain}</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 rounded-full border border-stonewash/70 bg-white/60 p-1 lg:flex" aria-label="Primary navigation">
      {navLinks.map((link) => (
        <a
          class:list={[
            "focus-ring rounded-full px-4 py-2 text-sm font-semibold transition",
            isActive(link.href) ? "bg-forest-700 text-white shadow-sm" : "text-ink hover:bg-forest-50 hover:text-forest-700"
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
          href={link.href}
        >{link.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a class="focus-ring inline-flex items-center gap-2 rounded-full border border-forest-200 bg-forest-50 px-3 py-2 text-forest-700 transition hover:-translate-y-0.5 hover:border-forest-400 hover:bg-forest-100 sm:px-4 sm:py-2.5" href={site.phoneHref} aria-label={`Call ${site.phone}`}>
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z" />
        </svg>
        <span class="whitespace-nowrap text-sm font-extrabold tracking-wide sm:text-base">{site.phone}</span>
      </a>
      <a class="focus-ring hidden items-center gap-2 rounded-full bg-forest-700 px-5 py-2.5 text-sm font-bold text-white shadow-glow transition hover:-translate-y-0.5 hover:bg-forest-600 sm:inline-flex" href="/contact/">
        Free Inspection
      </a>
    </div>
  </div>
  <nav class="border-t border-stonewash/70 bg-white/50 lg:hidden" aria-label="Mobile navigation">
    <div class="container flex gap-2 overflow-x-auto py-2.5 text-sm font-semibold">
      {navLinks.map((link) => (
        <a
          class:list={[
            "focus-ring shrink-0 rounded-full px-3 py-1.5 transition",
            isActive(link.href) ? "bg-forest-700 text-white" : "text-ink hover:text-forest-700"
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
          href={link.href}
        >{link.label}</a>
      ))}
    </div>
  </nav>
</header>
