---
type Crumb = {
  label: string;
  href?: string;
};

type Props = {
  crumbs: Crumb[];
};

const { crumbs } = Astro.props;
---

<nav class="container pt-6 text-sm" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-2 text-ink/55">
    {crumbs.map((crumb, index) => (
      <li class="flex items-center gap-2">
        {crumb.href ? <a class="focus-ring rounded-md font-semibold transition hover:text-forest-700" href={crumb.href}>{crumb.label}</a> : <span class="font-semibold text-ink">{crumb.label}</span>}
        {index < crumbs.length - 1 && (
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-3.5 w-3.5 text-forest-300" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6" /></svg>
        )}
      </li>
    ))}
  </ol>
</nav>
