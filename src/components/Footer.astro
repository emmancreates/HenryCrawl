---
import { site, business } from "@data/site";

const dayShort: Record<string, string> = {
  Monday: "Mon", Tuesday: "Tue", Wednesday: "Wed", Thursday: "Thu",
  Friday: "Fri", Saturday: "Sat", Sunday: "Sun"
};
const fmtTime = (t: string) => {
  const [h, m] = t.split(":").map(Number);
  const period = h >= 12 ? "PM" : "AM";
  const hour = h % 12 === 0 ? 12 : h % 12;
  return m === 0 ? `${hour} ${period}` : `${hour}:${String(m).padStart(2, "0")} ${period}`;
};
const hours = business.hours.map((h) => {
  const days = h.days.length > 1 ? `${dayShort[h.days[0]]}–${dayShort[h.days[h.days.length - 1]]}` : dayShort[h.days[0]];
  return { days, time: `${fmtTime(h.opens)} – ${fmtTime(h.closes)}` };
});
---

<footer class="relative mt-8 overflow-hidden bg-forest-950 text-white">
  <div class="pointer-events-none absolute -right-20 -top-24 h-72 w-72 rounded-full bg-forest-700/40 blur-3xl"></div>
  <div class="pointer-events-none absolute -left-16 bottom-0 h-64 w-64 rounded-full bg-clay/10 blur-3xl"></div>

  <div class="container relative">
    <div class="grid gap-12 py-16 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1.2fr]">
      <div>
        <a href="/" class="focus-ring flex items-center gap-3 rounded-2xl" aria-label="Henry Crawl Solutions home">
          <span class="grid h-11 w-11 place-items-center rounded-2xl bg-forest-700 text-white">
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 11.5 12 4l9 7.5" /><path d="M6 10.5V20h12v-9.5" /><path d="M8.5 16.5h7" /><path d="M9.5 13.5h5" />
            </svg>
          </span>
          <span class="text-base font-extrabold">{site.name}</span>
        </a>
        <p class="mt-5 max-w-xs text-sm leading-6 text-white/65">{site.tagline}</p>
      </div>

      <div>
        <h2 class="text-xs font-bold uppercase tracking-[0.16em] text-forest-300">Services</h2>
        <ul class="mt-4 space-y-2.5 text-sm text-white/72">
          <li><a class="transition hover:text-white" href="/crawl-space-encapsulation/">Crawl Space Encapsulation</a></li>
          <li><a class="transition hover:text-white" href="/crawl-space-repair/">Crawl Space Repair</a></li>
          <li><a class="transition hover:text-white" href="/vapor-barrier-installation/">Vapor Barrier Installation</a></li>
          <li><a class="transition hover:text-white" href="/crawl-space-moisture-control/">Moisture Control</a></li>
          <li><a class="transition hover:text-white" href="/services/">All Services</a></li>
        </ul>
      </div>

      <div>
        <h2 class="text-xs font-bold uppercase tracking-[0.16em] text-forest-300">Service Areas</h2>
        <ul class="mt-4 space-y-2.5 text-sm text-white/72">
          <li><a class="transition hover:text-white" href="/service-areas/mcdonough-ga/">McDonough</a></li>
          <li><a class="transition hover:text-white" href="/service-areas/stockbridge-ga/">Stockbridge</a></li>
          <li><a class="transition hover:text-white" href="/service-areas/locust-grove-ga/">Locust Grove</a></li>
          <li><a class="transition hover:text-white" href="/service-areas/hampton-ga/">Hampton</a></li>
          <li><a class="transition hover:text-white" href="/service-areas/">All Service Areas</a></li>
        </ul>
      </div>

      <div>
        <h2 class="text-xs font-bold uppercase tracking-[0.16em] text-forest-300">Contact</h2>
        <ul class="mt-4 space-y-2.5 text-sm text-white/72">
          <li><a class="inline-flex items-center gap-2 transition hover:text-white" href={site.phoneHref}><svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 text-forest-300" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.1 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z" /></svg>{site.phone}</a></li>
          <li><a class="inline-flex items-center gap-2 transition hover:text-white" href={site.emailHref}><svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 text-forest-300" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" /></svg>{site.email}</a></li>
          <li class="flex items-start gap-2 text-white/72"><svg aria-hidden="true" viewBox="0 0 24 24" class="mt-0.5 h-4 w-4 shrink-0 text-forest-300" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="2.5" /></svg><span>Serving {business.address.locality}, {business.address.region} &amp; Henry County</span></li>
        </ul>
        <div class="mt-5">
          <h3 class="text-xs font-bold uppercase tracking-[0.16em] text-forest-300">Hours</h3>
          <ul class="mt-3 space-y-1 text-sm text-white/72">
            {hours.map((h) => (
              <li class="flex justify-between gap-4"><span>{h.days}</span><span class="text-white/55">{h.time}</span></li>
            ))}
            <li class="flex justify-between gap-4"><span>Sun</span><span class="text-white/55">Closed</span></li>
          </ul>
        </div>
        <a class="focus-ring mt-5 inline-flex rounded-full bg-white px-5 py-2.5 text-sm font-bold text-forest-700 transition hover:bg-forest-50" href="/contact/">{site.primaryCta}</a>
        <p class="mt-5 text-xs leading-relaxed text-white/45">Phone, hours, and service-area details are placeholders &mdash; replace with verified business information before launch.</p>
      </div>
    </div>

    <div class="border-t border-white/10 py-6">
      <div class="flex flex-col gap-2 text-sm text-white/55 sm:flex-row sm:items-center sm:justify-between">
        <p>&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</p>
        <p>{site.tagline}</p>
      </div>
    </div>
  </div>
</footer>
