---
import BaseLayout from "@layouts/BaseLayout.astro";
import CTASection from "@components/CTASection.astro";
import FAQ from "@components/FAQ.astro";
import Hero from "@components/Hero.astro";
import LocationGrid from "@components/LocationGrid.astro";
import ProcessSteps from "@components/ProcessSteps.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ServiceGrid from "@components/ServiceGrid.astro";
import TrustBar from "@components/TrustBar.astro";
import { blogPosts } from "@data/blog";
import { homeFaqs } from "@data/faqs";
import { site } from "@data/site";
import { buildGraph } from "@data/schema";

const title = "Crawl Space Encapsulation & Repair in McDonough, GA | Henry Crawl Solutions";
const description = "Crawl space encapsulation, moisture control, vapor barriers, drainage & repair in McDonough and Henry County, GA. Request a free crawl space inspection from Henry Crawl Solutions.";

const faqSchema = {
  "@type": "FAQPage",
  mainEntity: homeFaqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  })),
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["h1", ".home-intro"]
  }
};
const schema = buildGraph([faqSchema]);
---

<BaseLayout title={title} description={description} canonical="/" schema={schema}>
  <Hero
    title="Crawl Space Encapsulation & Repair in McDonough, GA"
    subheadline="Henry Crawl Solutions helps Henry County homeowners fix damp crawl spaces, musty odors, standing water, damaged vapor barriers, and moisture problems under the home."
  />
  <TrustBar />

  <section class="border-b border-stonewash/70 bg-sand/50 py-20">
    <div class="container">
      <div class="home-intro mx-auto max-w-3xl text-center">
        <span class="eyebrow justify-center"><span class="h-1.5 w-1.5 rounded-full bg-clay"></span>Crawl space help for McDonough &amp; Henry County, GA</span>
        <h2 class="font-display mt-4 text-3xl font-semibold leading-tight text-ink sm:text-[2.4rem]">Crawl space encapsulation, moisture control &amp; repair in McDonough, GA</h2>
        <p class="mt-5 text-lg leading-8 text-ink/70">
          Henry Crawl Solutions helps McDonough and Henry County homeowners take the guesswork out of a damp, musty, or wet crawl space. From <a class="font-semibold text-forest-700 underline-offset-4 hover:underline" href="/crawl-space-encapsulation/">crawl space encapsulation</a> and <a class="font-semibold text-forest-700 underline-offset-4 hover:underline" href="/vapor-barrier-installation/">vapor barrier installation</a> to <a class="font-semibold text-forest-700 underline-offset-4 hover:underline" href="/crawl-space-moisture-control/">moisture control</a>, <a class="font-semibold text-forest-700 underline-offset-4 hover:underline" href="/crawl-space-drainage/">drainage</a>, and <a class="font-semibold text-forest-700 underline-offset-4 hover:underline" href="/wet-crawl-space-repair/">wet crawl space repair</a>, the first step is always the same: a clear inspection that explains what is happening under your home and what it will take to fix it.
        </p>
        <p class="mt-4 text-lg leading-8 text-ink/70">
          Serving McDonough, Stockbridge, Locust Grove, Hampton, and the rest of Henry County, GA. <a class="font-semibold text-forest-700 underline-offset-4 hover:underline" href="/contact/">Request a free crawl space inspection</a> or call <a class="font-bold text-forest-700" href={site.phoneHref}>{site.phone}</a>.
        </p>
      </div>

      <div class="mt-12 grid gap-4 sm:grid-cols-3">
        {[
          {
            t: "What is crawl space encapsulation?",
            d: "Sealing the exposed ground and walls of a crawl space with a durable vapor barrier, then pairing it with drainage or humidity control to keep moisture out."
          },
          {
            t: "Why do crawl spaces get damp here?",
            d: "Georgia's humid climate, clay-heavy soil, and traditional vented crawl spaces let ground and outdoor moisture build up under the home, especially after heavy rain."
          },
          {
            t: "How much does it cost?",
            d: "Cost depends on size, access, drainage, and liner type. An on-site crawl space inspection in McDonough is the most reliable way to get an accurate estimate."
          }
        ].map((card) => (
          <article class="card p-6 text-left">
            <h3 class="text-base font-extrabold text-ink">{card.t}</h3>
            <p class="mt-3 text-sm leading-6 text-ink/65">{card.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <SectionHeading
        eyebrow="Why it matters"
        title="Moisture under the home shows up in everyday ways."
        text="Musty rooms, damp insulation, sagging floor concerns, or water on top of an old liner can all point back to the crawl space. We keep the first step simple: identify the condition, explain practical options, and help you request a clear estimate."
      />
      <div class="grid gap-3 sm:grid-cols-2">
        {["crawl space encapsulation McDonough GA", "crawl space repair McDonough GA", "crawl space moisture control Henry County GA", "vapor barrier installation McDonough GA", "wet crawl space repair McDonough GA", "drainage and dehumidifier planning"].map((item) => (
          <div class="flex items-start gap-2.5 rounded-2xl border border-stonewash/80 bg-white p-4 text-sm font-bold text-ink/80 shadow-card">
            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-clay"></span>
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-stonewash/70 bg-sand/50 py-20">
    <div class="container">
      <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <SectionHeading
          eyebrow="What we help with"
          title="Crawl space services"
          text="Choose the service that best matches what you are seeing, or request an inspection if you are unsure."
        />
        <a class="focus-ring inline-flex shrink-0 items-center gap-1.5 rounded-full border border-forest-200 bg-white px-5 py-2.5 text-sm font-bold text-forest-700 transition hover:-translate-y-0.5 hover:border-forest-400" href="/services/">
          View all services
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg>
        </a>
      </div>
      <ServiceGrid />
    </div>
  </section>

  <section class="py-20">
    <div class="container grid gap-12 lg:grid-cols-2 lg:items-center">
      <SectionHeading
        eyebrow="Warning signs"
        title="Common crawl space problems"
        text="A damp crawl space does not always look dramatic. Small signals can still point to moisture moving through the soil, walls, vents, or drainage paths."
      />
      <div class="grid gap-3">
        {["Standing water after heavy rain", "Musty odors in rooms above the crawl space", "Damaged or missing vapor barrier", "Condensation on ducts, pipes, or framing", "Mold-like staining or damp insulation"].map((problem) => (
          <div class="flex items-center gap-3 rounded-2xl border border-stonewash/80 bg-white p-4 font-semibold text-ink/80 shadow-card">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-clay-50 text-clay-600">
              <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4" /><path d="M12 17h.01" /><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z" /></svg>
            </span>
            {problem}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container">
      <div class="relative overflow-hidden rounded-[2rem] bg-forest-radial px-8 py-14 text-white shadow-glow sm:px-12">
        <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-white/10 blur-2xl"></div>
        <div class="pointer-events-none absolute -bottom-20 -left-10 h-56 w-56 rounded-full bg-clay/20 blur-2xl"></div>
        <div class="relative mx-auto max-w-3xl text-center">
          <span class="eyebrow justify-center text-forest-200"><span class="h-1.5 w-1.5 rounded-full bg-honey"></span>Local conditions</span>
          <h2 class="font-display mt-4 text-3xl font-semibold leading-tight sm:text-4xl">Why crawl spaces stay damp in Henry County, GA</h2>
          <p class="mt-5 text-base leading-7 text-white/80">
            Crawl space moisture is common across McDonough and Henry County for a few local reasons. Understanding the cause is the first step toward the right fix &mdash; whether that is a vapor barrier, drainage, a dehumidifier, or full encapsulation.
          </p>
        </div>
        <div class="relative mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { t: "Humid Georgia climate", d: "Long, humid summers push warm, moist air into vented crawl spaces, where it condenses on cooler ducts, pipes, and framing." },
            { t: "Clay-heavy soil", d: "Henry County's red clay holds water and drains slowly, keeping the ground under the home damp long after a storm passes." },
            { t: "Traditional vented design", d: "Many older homes have open foundation vents that let outdoor humidity and ground moisture build up beneath the floor." },
            { t: "Heavy seasonal rain", d: "Downspouts, grading, and runoff can send rainwater toward the foundation, leading to standing water and wet crawl spaces." }
          ].map((card) => (
            <article class="rounded-2xl border border-white/15 bg-white/5 p-5 backdrop-blur">
              <h3 class="text-base font-extrabold">{card.t}</h3>
              <p class="mt-2 text-sm leading-6 text-white/75">{card.d}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-stonewash/70 bg-sand/50 py-20">
    <div class="container">
      <SectionHeading
        eyebrow="Simple process"
        title="How the inspection process works"
        align="center"
      />
      <div class="mt-12">
        <ProcessSteps />
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <SectionHeading
          eyebrow="Where we work"
          title="McDonough & Henry County service area"
          text="We focus on McDonough, Henry County, and nearby Georgia communities where homeowners deal with crawl space humidity, damaged liners, and storm-related wet crawl spaces."
        />
        <a class="btn-primary mt-7" href="/service-areas/">
          Serving Henry County
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg>
        </a>
      </div>
      <div class="relative">
        <div class="pointer-events-none absolute -right-5 -top-5 h-24 w-24 rounded-3xl bg-clay/10"></div>
        <img class="relative aspect-[16/11] w-full rounded-[1.6rem] border border-white/60 object-cover shadow-lift" src="/crawl-space-hero.png" alt="Clean crawl space moisture control work area" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="border-y border-stonewash/70 bg-sand/50 py-20">
    <div class="container">
      <SectionHeading
        eyebrow="Local coverage"
        title="Featured service areas"
        align="center"
      />
      <div class="mt-12">
        <LocationGrid slugs={["mcdonough-ga", "stockbridge-ga", "locust-grove-ga", "hampton-ga"]} />
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container">
      <SectionHeading
        eyebrow="Good to know"
        title="Crawl space FAQ"
        align="center"
      />
      <div class="mt-12">
        <FAQ items={homeFaqs} />
      </div>
    </div>
  </section>

  <section class="border-y border-stonewash/70 bg-sand/50 py-20">
    <div class="container">
      <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <SectionHeading
          eyebrow="Guides &amp; insight"
          title="Crawl space guides for homeowners"
          text="Practical, McDonough-focused answers on encapsulation cost, moisture signs, vapor barriers, and musty odors."
        />
        <a class="focus-ring inline-flex shrink-0 items-center gap-1.5 rounded-full border border-forest-200 bg-white px-5 py-2.5 text-sm font-bold text-forest-700 transition hover:-translate-y-0.5 hover:border-forest-400" href="/blog/">
          Read the blog
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg>
        </a>
      </div>
      <div class="grid gap-5 md:grid-cols-2">
        {blogPosts.map((post) => (
          <article class="card group relative flex flex-col p-7 hover:-translate-y-1 hover:border-forest-200 hover:shadow-lift">
            <span class="eyebrow"><span class="h-1.5 w-1.5 rounded-full bg-clay"></span>Crawl space guide</span>
            <h3 class="mt-4 text-xl font-extrabold leading-tight text-ink"><a class="focus-ring rounded-md after:absolute after:inset-0" href={`/blog/${post.slug}/`}>{post.title}</a></h3>
            <p class="mt-3 text-sm leading-6 text-ink/65">{post.description}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-bold text-forest-700">
              Read the guide
              <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 transition group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg>
            </span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
